{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "minimumReleaseAge": "7 days",
  "rebaseWhen": "behind-base-branch",
  "semanticCommits": "enabled",
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "description": "Batch every non-security update into a single weekly PR",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "all dependencies",
      "schedule": [
        "before 6am on monday"
      ]
    },
    {
      "description": "Bump the root go.mod go directive so the language version stays in sync with the mise toolchain",
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "go.mod"
      ],
      "matchDepTypes": [
        "golang"
      ],
      "matchDepNames": [
        "go"
      ],
      "rangeStrategy": "bump"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "uses: jdx/mise-action@.*\\n\\s+with:\\n\\s+version: (?<currentValue>.*)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases"
    }
  ]
}
